#!/usr/bin/env bash
# ABOUTME: Install dependencies for make-audiobook across macOS and Linux distros.
# ABOUTME: Detects package manager, installs packages, sets up TTS engines, and symlinks executables.
set -euo pipefail
IFS=$'\n\t'

VERSION="3.8.5"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

die() {
    echo "⛔️ $*" >&2
    exit 1
}

warn() {
    echo "⚠️  $*" >&2
}

info() {
    echo "ℹ️  $*"
}

checkmark() {
    echo "✅ $*"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: install-dependencies [OPTIONS]

Install dependencies for make-audiobook.

Options:
  -h, --help      Show this help message
  --version       Show version
  --link-only     Only create symlinks (skip package installation)

Supported platforms:
  macOS           Homebrew
  Debian/Ubuntu   apt
  Fedora/RHEL     dnf
  Arch Linux      pacman
  Alpine          apk
  NixOS           nix (prints instructions)
EOF
}

# ---------------------------------------------------------------------------
# Package manager detection
# ---------------------------------------------------------------------------

detect_package_manager() {
    if command -v brew >/dev/null 2>&1; then
        echo "brew"
    elif command -v apt-get >/dev/null 2>&1; then
        echo "apt"
    elif command -v dnf >/dev/null 2>&1; then
        echo "dnf"
    elif command -v pacman >/dev/null 2>&1; then
        echo "pacman"
    elif command -v apk >/dev/null 2>&1; then
        echo "apk"
    elif [ -e /etc/NIXOS ] || command -v nix-env >/dev/null 2>&1; then
        echo "nix"
    else
        echo "unknown"
    fi
}

# ---------------------------------------------------------------------------
# Package installation per manager
# ---------------------------------------------------------------------------

install_brew() {
    local packages
    packages=(pipx "python@3.12" ffmpeg pandoc fzf fd espeak-ng)

    local brew_installed
    brew_installed="$(brew list -1)"

    local pkg
    for pkg in "${packages[@]}"; do
        if echo "$brew_installed" | grep -q -E "^${pkg}$"; then
            checkmark "$pkg is already installed."
        else
            info "Installing $pkg..."
            if ! brew install "$pkg"; then
                warn "Failed to install $pkg via Homebrew."
            fi
        fi
    done
}

install_apt() {
    local packages
    packages=(ffmpeg pandoc fzf fd-find espeak-ng pipx python3 python3-venv)

    info "Updating package index..."
    if ! sudo apt-get update -qq; then
        warn "Failed to update package index."
    fi

    local pkg
    for pkg in "${packages[@]}"; do
        if dpkg -l "$pkg" 2>/dev/null | grep -q "^ii"; then
            checkmark "$pkg is already installed."
        else
            info "Installing $pkg..."
            if ! sudo apt-get install -y "$pkg"; then
                warn "Failed to install $pkg via apt."
            fi
        fi
    done
}

install_dnf() {
    local packages
    packages=(ffmpeg pandoc fzf fd-find espeak-ng pipx python3)

    local pkg
    for pkg in "${packages[@]}"; do
        if rpm -q "$pkg" >/dev/null 2>&1; then
            checkmark "$pkg is already installed."
        else
            info "Installing $pkg..."
            if ! sudo dnf install -y "$pkg"; then
                warn "Failed to install $pkg via dnf."
            fi
        fi
    done
}

install_pacman() {
    local packages
    packages=(ffmpeg pandoc fzf fd espeak-ng python-pipx python)

    local pkg
    for pkg in "${packages[@]}"; do
        if pacman -Q "$pkg" >/dev/null 2>&1; then
            checkmark "$pkg is already installed."
        else
            info "Installing $pkg..."
            if ! sudo pacman -S --noconfirm "$pkg"; then
                warn "Failed to install $pkg via pacman."
            fi
        fi
    done
}

install_apk() {
    local packages
    packages=(ffmpeg pandoc fzf fd espeak-ng pipx python3)

    local pkg
    for pkg in "${packages[@]}"; do
        if apk info -e "$pkg" >/dev/null 2>&1; then
            checkmark "$pkg is already installed."
        else
            info "Installing $pkg..."
            if ! sudo apk add "$pkg"; then
                warn "Failed to install $pkg via apk."
            fi
        fi
    done
}

print_nix_instructions() {
    cat <<'EOF'
NixOS detected. Package installation is managed declaratively.

Option 1 — Use our Nix flake (recommended):
  nix develop github:tigger04/make-audiobook

Option 2 — Add to your system configuration (configuration.nix or flake.nix):
  environment.systemPackages = with pkgs; [
    ffmpeg
    pandoc
    fzf
    fd
    espeak-ng
    pipx
    python312
  ];

Option 3 — Install imperatively (temporary):
  nix-env -iA nixpkgs.ffmpeg nixpkgs.pandoc nixpkgs.fzf nixpkgs.fd \
    nixpkgs.espeak-ng nixpkgs.pipx nixpkgs.python312

After installing system packages, install TTS engines:
  pipx install kokoro-tts
  pipx install piper-tts
EOF
}

print_unknown_instructions() {
    cat <<'EOF'
Could not detect a supported package manager.

make-audiobook requires the following dependencies:
  - ffmpeg        (audio encoding)
  - pandoc        (document conversion)
  - fzf           (interactive voice selection, CLI)
  - fd            (fast file finder)
  - espeak-ng     (phoneme backend for Kokoro TTS)
  - pipx          (Python CLI tool installer)
  - python3       (Python 3.12+ recommended)

After installing system packages, install TTS engines via pipx:
  pipx install kokoro-tts
  pipx install piper-tts

For Piper voices:
  ./piper-voices-setup
EOF
}

# ---------------------------------------------------------------------------
# TTS engine installation via pipx
# ---------------------------------------------------------------------------

install_tts_engines() {
    local _os="$1"

    if ! command -v pipx >/dev/null 2>&1; then
        warn "pipx not found. Cannot install TTS engines."
        warn "Install pipx first, then run:"
        warn "  pipx install kokoro-tts"
        warn "  pipx install piper-tts"
        return
    fi

    # kokoro-tts (default engine)
    if pipx list 2>/dev/null | grep -q "kokoro-tts"; then
        checkmark "kokoro-tts is already installed."
    else
        info "Installing kokoro-tts (default TTS engine)..."
        if [[ "$_os" == "Darwin" ]]; then
            # macOS: kokoro-tts requires Python <3.13
            if ! pipx install kokoro-tts --python python3.12; then
                warn "Failed to install kokoro-tts. Install manually:"
                warn "  pipx install kokoro-tts --python python3.12"
            fi
        else
            if ! pipx install kokoro-tts; then
                warn "Failed to install kokoro-tts. Install manually:"
                warn "  pipx install kokoro-tts"
            fi
        fi
    fi

    # piper-tts (alternative engine)
    if pipx list 2>/dev/null | grep -q "piper-tts"; then
        checkmark "piper-tts is already installed."
    else
        info "Installing piper-tts (alternative TTS engine)..."
        if ! pipx install piper-tts; then
            warn "Failed to install piper-tts. Install manually:"
            warn "  pipx install piper-tts"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Symlink executables into ~/.local/bin
# ---------------------------------------------------------------------------

create_symlinks() {
    local target_dir="${HOME}/.local/bin"
    local executables
    executables=(make-audiobook piper-voices-setup)

    mkdir -p "$target_dir"

    local exe source target
    for exe in "${executables[@]}"; do
        source="${SCRIPT_DIR}/${exe}"
        target="${target_dir}/${exe}"

        if [[ ! -f "$source" ]]; then
            warn "Source not found: $source"
            continue
        fi

        if [[ -L "$target" ]]; then
            # Already a symlink — update it
            rm -- "$target"
        elif [[ -f "$target" ]]; then
            warn "$target already exists and is not a symlink. Skipping."
            continue
        fi

        ln -s "$source" "$target"
        checkmark "Symlinked $exe -> $target"
    done

    # Check if ~/.local/bin is in PATH
    case ":${PATH}:" in
        *":${target_dir}:"*)
            checkmark "${target_dir} is already in your PATH."
            ;;
        *)
            echo ""
            info "${target_dir} is not in your PATH."
            info "Add it to your shell profile:"
            info "  export PATH=\"\${HOME}/.local/bin:\${PATH}\""
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        --version)
            echo "install-dependencies ${VERSION}"
            exit 0
            ;;
        --link-only)
            info "Creating symlinks only..."
            create_symlinks
            exit 0
            ;;
    esac

    local _os
    _os="$(uname -s)"

    echo "🔷 Installing dependencies for make-audiobook..."
    echo ""

    # Detect and use package manager
    local pkg_mgr
    pkg_mgr="$(detect_package_manager)"
    info "Detected package manager: ${pkg_mgr}"
    echo ""

    case "$pkg_mgr" in
        brew)   install_brew ;;
        apt)    install_apt ;;
        dnf)    install_dnf ;;
        pacman) install_pacman ;;
        apk)    install_apk ;;
        nix)    print_nix_instructions ;;
        *)      print_unknown_instructions ;;
    esac

    echo ""

    # Install TTS engines via pipx (skip for nix/unknown — they handle it themselves)
    if [[ "$pkg_mgr" != "nix" && "$pkg_mgr" != "unknown" ]]; then
        install_tts_engines "$_os"
        echo ""
    fi

    # Create symlinks
    create_symlinks

    echo ""
    echo "🎉 Done! Run 'make-audiobook --help' to get started."
}

main "$@"

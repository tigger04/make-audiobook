#!/usr/bin/env bash
# ABOUTME: CLI tool to convert documents to audiobooks using Piper or Kokoro TTS.
# ABOUTME: Supports txt, epub, docx, md, html, pdf, mobi with batch processing and ID3 tagging.

set -e -o pipefail
shopt -s dotglob lastpipe

# --- Shell helpers (inlined from shell-and-scripting-helpers) ---
cmd_base="$(basename "$0")"
cmd_dir="$(cd "$(dirname "$0")" && pwd)"
die()              { printf '💀 %s died: %s\n' "$cmd_base" "$*" >&2; exit 1; }
warn()             { echo -e "⚠️ $*" >&2; }
errortext()        { echo -e "⛔️ $*" >&2; }
info()             { echo -e "🚹 $*" >&2; }
checktext()        { echo "☑️ $*" >&2; }
show_cmd_execute() { echo "⚡️ $*" >&2; "$@"; }
hline() {
   local cols
   cols="${COLUMNS:-65}"
   if [[ $# -eq 0 ]]; then
      printf '%*s\n' "$cols" '' | tr ' ' '='
   else
      local text="$*" pad
      pad=$(( (cols - ${#text} - 4) / 2 ))
      printf '%*s> %s <%*s\n' "$pad" '' "$text" "$pad" '' | tr ' ' '-'
   fi
}

# Array to track temporary files and directories for cleanup
cleanup_targets=()

# Cleanup function that will run on exit/error
cleanup() {
   local exit_code=$?

   # Clean up all tracked temporary files and directories
   for target in "${cleanup_targets[@]}"; do
      if [[ -n "$target" && -e "$target" ]]; then
         if [[ -d "$target" ]]; then
            rm -rf "$target"
         else
            rm -f "$target"
         fi
      fi
   done

   # Exit with the original exit code
   exit $exit_code
}

# Set trap to run cleanup on EXIT, ERR, INT, and TERM signals
trap cleanup EXIT ERR INT TERM

# Function to register files/directories for cleanup
register_for_cleanup() {
   cleanup_targets+=("$@")
}

VERSION="3.8.0"

if [[ "${1:-}" =~ ^--?[Vv](ersion)?$ ]]; then
   echo "make-audiobook $VERSION"
   exit 0
fi

show_usage() {
   cat - <<EOM
USAGE:
   $cmd_base [OPTIONS] TEXT_FILE [TEXT_FILE2 ...]

WTF:
   Convert document(s) to audio using Piper TTS.
   Supports: txt, epub, docx, md, html, pdf, mobi.
   Supports batch processing with ID3 tagging.
   On first run, if no Piper voices found, the script will prompt to run
   piper-voices-setup which downloads a bunch of voices.
   Note: .mobi support requires Calibre (ebook-convert).

OPTIONS:
   -h / --help (show this help message)
   -V / --version (show version)
   -u / --update-voices (update installed Piper voices)
   -r / --random-voice[=FILTER] (use a random voice for each file)
   -l / --list-voices (list voices installed)
   -s / --length_scale=<SCALE> (set length scale or speed of TTS.
                               - higher values = slower speech. Defaults to 1.5
                                 as I find 1.0 a bit fast for audiobooks.)
   --engine=ENGINE (Use alternative TTS engine.
                   - Options: piper (default), kokoro, whisperspeech
                   - Kokoro requires: pip install kokoro-tts, espeak-ng
                   - WhisperSpeech requires: pip install whisperspeech
                   - Kokoro natively handles .epub and .pdf with chapter detection.)
   --speed=SPEED (set speed multiplier for Kokoro engine.
                 - 1.0 = normal, 1.5 = faster. No effect on Piper.)
   --non-interactive (skip prompts, use defaults for missing values)
   --author=NAME (set author name for ID3 tags)
   --title=TITLE (set title for ID3 tags)
   --voice=PATH (specify voice model path directly)
EOM
}

if [[ $# -eq 0 ]]; then
   show_usage
   exit 2
fi

if [[ $1 =~ ^--?h(elp)?$ ]]; then
   show_usage
   exit 0
fi

mapfile -t voices_installed < <(fd . -e onnx ~/.local/share/piper/voices)
if [ ${#voices_installed[@]} -eq 0 ]; then
   hline running piper-voices-setup
   show_cmd_execute ~/bin/piper-voices-setup
fi

list_installed_voices() {
   if [ ${#voices_installed[@]} -eq 0 ]; then
      errortext "No voices installed."
   else
      echo "INSTALLED VOICES:"
      for voice in "${voices_installed[@]}"; do
         display_voice="$(basename "$voice" .onnx)"
         case "$display_voice" in
         en_GB-*)
            echo -n "🇬🇧"
            ;;
         en_US-*)
            echo -n "🇺🇸"
            ;;
         *)
            echo -n "🌍"
            ;;
         esac
         echo -n "$display_voice "
         case "$display_voice" in
         *-high)
            echo "⭐️⭐️⭐️"
            ;;
         *-medium)
            echo "⭐️⭐️"
            ;;
         *-low)
            echo "⭐️"
            ;;
         esac
      done
      cat <<EOM
For Piper voices, medium is usually good enough, best trade-off between 
speed and quality. High quality voices may produce better results, but
require significantly more processing time.
EOM
   fi
}

# defaults
random=false
random_filter=.
source_files=()
length_scale=1.5
non_interactive=false
author=""
book_title=""
voice_model=""
engine="piper"
speed="1.0"

while [ $# -gt 0 ]; do
   case "$1" in
   -r* | --random*)
      random=true
      # get random_filter from `--random=<filter>`
      random_filter="${1#*=}"
      if [[ "$1" != *"="* ]] || [ -z "$random_filter" ]; then
         random_filter=.
      else
         info "Using random filter: $random_filter"
      fi
      ;;
   -u | --update-voices)
      cd "$cmd_dir"
      show_cmd_execute ./piper-voices-setup
      exit $?
      ;;
   -l | --list-voices)
      list_installed_voices
      exit $?
      ;;
   -s* | --length_scale*)
      if [[ "$1" == *=* ]]; then
         length_scale="${1#*=}"
         if ! [[ $length_scale =~ ^[0-9]+([.][0-9]+)?$ ]]; then
            die "Length scale must be a positive number (integer or decimal)"
         fi
         if (($(echo "$length_scale <= 0" | bc -l))); then
            die "Length scale must be greater than 0"
         fi
         info "Using length scale: $length_scale"
      else
         die "Length scale option requires a value, e.g. --length_scale=1.5"
      fi
      ;;
   --non-interactive)
      non_interactive=true
      ;;
   --author*)
      if [[ "$1" == *=* ]]; then
         author="${1#*=}"
      else
         die "Author option requires a value, e.g. --author=\"John Doe\""
      fi
      ;;
   --title*)
      if [[ "$1" == *=* ]]; then
         book_title="${1#*=}"
      else
         die "Title option requires a value, e.g. --title=\"My Book\""
      fi
      ;;
   --voice*)
      if [[ "$1" == *=* ]]; then
         voice_model="${1#*=}"
      else
         die "Voice option requires a value, e.g. --voice=/path/to/voice.onnx"
      fi
      ;;
   --engine*)
      if [[ "$1" == *=* ]]; then
         engine="${1#*=}"
         case "$engine" in
            piper|kokoro|whisperspeech)
               info "Using engine: $engine"
               ;;
            *)
               die "Unknown engine: $engine. Options: piper, kokoro, whisperspeech"
               ;;
         esac
      else
         die "Engine option requires a value, e.g. --engine=kokoro"
      fi
      ;;
   --speed*)
      if [[ "$1" == *=* ]]; then
         speed="${1#*=}"
         if ! [[ $speed =~ ^[0-9]+([.][0-9]+)?$ ]]; then
            die "Speed must be a positive number (integer or decimal)"
         fi
         info "Using speed: $speed"
      else
         die "Speed option requires a value, e.g. --speed=1.5"
      fi
      ;;
   *)
      source_files+=("$1")
      ;;
   esac
   shift
done

# declare -p random random_filter source_files voices_installed cleanup_targets
# exit

# Validate voice model path for Piper (file must exist)
if [[ -n "$voice_model" ]] && [[ "$engine" != "kokoro" ]] && [[ ! -f "$voice_model" ]]; then
   die "Voice model file not found: $voice_model"
fi

# Kokoro engine: validate dependencies
if [[ "$engine" == "kokoro" ]]; then
   if ! command -v kokoro-tts &>/dev/null; then
      die "kokoro-tts not found. Install: pipx install kokoro-tts"
   fi
   if ! command -v espeak-ng &>/dev/null; then
      die "espeak-ng not found. Install: brew install espeak"
   fi
fi

if ! $non_interactive; then
   info "The following metadata will be applied to all ${#source_files[@]} files specified, if entered."
   # Prompt for author and book (optional)
   echo -n "Enter author name (optional): "
   read -r author
   echo -n "Enter book title (optional): "
   read -r book_title
fi

# Function to extract track number from filename
extract_track_number() {
   local filename="$1"
   local base_name
   base_name="$(strip_extension "$filename")"

   # Look for clear integers in the filename
   if [[ $base_name =~ ([0-9]+) ]]; then
      echo "${BASH_REMATCH[1]}"
   else
      echo ""
   fi
}

# Function to strip the file extension from a path
strip_extension() {
   local filename="$1"
   local base
   base="$(basename "$filename")"
   # Strip known extensions
   case "${base,,}" in
      *.mobi) echo "${base%.mobi}" ;;
      *.epub) echo "${base%.epub}" ;;
      *.docx) echo "${base%.docx}" ;;
      *.html) echo "${base%.html}" ;;
      *.pdf)  echo "${base%.pdf}" ;;
      *.md)   echo "${base%.md}" ;;
      *.txt)  echo "${base%.txt}" ;;
      *)      echo "$base" ;;
   esac
}

# Function to convert a single file using Kokoro engine
convert_file_kokoro() {
   local input_file="$1"

   # Kokoro voice defaults to af_heart
   local kokoro_voice="${voice_model:-af_heart}"

   # Generate output filename based on input
   local target_mp3 base_name
   base_name="$(strip_extension "$input_file")"
   target_mp3="$(dirname "${input_file}")/${base_name}.mp3"

   hline "$(basename "$input_file") -> $target_mp3 (Kokoro)"

   mv_bak_if "$target_mp3"

   local tmpdir kokoro_input
   read -r tmpdir < <(mktemp -d)
   register_for_cleanup "$tmpdir"

   kokoro_input="$input_file"

   # Pre-convert .mobi to epub for Kokoro
   case "${input_file,,}" in
      *.mobi)
         if ! command -v ebook-convert &>/dev/null; then
            die "ebook-convert not found. Install Calibre: brew install calibre"
         fi
         local epub_tmp="$tmpdir/converted.epub"
         info "Converting .mobi to .epub via ebook-convert"
         ebook-convert "$input_file" "$epub_tmp" --no-default-epub-cover
         kokoro_input="$epub_tmp"
         ;;
      *.docx|*.md|*.html)
         # Formats Kokoro does not handle natively — extract text first
         local txt_tmp="$tmpdir/extracted.txt"
         info "Extracting text from $(basename "$input_file") via pandoc"
         pandoc "$input_file" --to plain --wrap=none -o "$txt_tmp"
         kokoro_input="$txt_tmp"
         ;;
   esac

   local cmd_args=(
      kokoro-tts
      "$kokoro_input"
      "$target_mp3"
      --voice "$kokoro_voice"
      --speed "$speed"
      --format mp3
   )

   info "Running: ${cmd_args[*]}"
   "${cmd_args[@]}"

   # Set ID3 tags if author or book title provided
   if [ -n "$author" ] || [ -n "$book_title" ]; then
      info "Setting ID3 tags for $target_mp3"
      local tag_args=()

      if [ -n "$author" ]; then
         tag_args+=(-metadata "artist=$author")
         tag_args+=(-metadata "album_artist=$author")
      fi
      if [ -n "$book_title" ]; then
         tag_args+=(-metadata "album=$book_title")
      fi

      local track_num
      track_num=$(extract_track_number "$input_file")
      if [ -n "$track_num" ]; then
         tag_args+=(-metadata "track=$track_num")
         info "Detected track number: $track_num"
      fi

      local temp_tagged
      temp_tagged="$(mktemp).mp3"
      register_for_cleanup "$temp_tagged"
      show_cmd_execute ffmpeg -i "$target_mp3" "${tag_args[@]}" -c copy "$temp_tagged" | oneline 2>&1
      mv "$temp_tagged" "$target_mp3"
   fi

   checktext "$target_mp3"
}

# Function to convert a single file using Piper engine
convert_file() {
   local input_text_file="$1"

   if $random; then
      read -r voice_model < <(fd "$random_filter" -e onnx ~/.local/share/piper/voices | shuf | head -n 1)
      info "Using random voice: $(basename "$voice_model")"
   fi

   if [ -z "$voice_model" ]; then
      die "No voice model could be determined"
   fi

   # Generate output filename based on input (strip any known extension)
   local target_mp3 base_name
   base_name="$(strip_extension "$input_text_file")"
   target_mp3="$(dirname "${input_text_file}")/${base_name}.mp3"

   hline "$(basename "$input_text_file") -> $target_mp3"

   mv_bak_if "$target_mp3"

   local tmpdir txt wav temp_tagged pandoc_input

   read -r tmpdir < <(mktemp -d)
   txt="$tmpdir/tmp.txt"
   wav="$tmpdir/tmp.wav"
   pandoc_input="$input_text_file"

   register_for_cleanup "$tmpdir" "$txt" "$wav"

   # Pre-convert .mobi files using Calibre's ebook-convert
   case "${input_text_file,,}" in
      *.mobi)
         if ! command -v ebook-convert &>/dev/null; then
            die "ebook-convert not found. Install Calibre: brew install calibre"
         fi
         local epub_tmp="$tmpdir/converted.epub"
         info "Converting .mobi to .epub via ebook-convert"
         ebook-convert "$input_text_file" "$epub_tmp" --no-default-epub-cover
         pandoc_input="$epub_tmp"
         ;;
   esac

   info "Converting $input_text_file to plain text"
   pandoc "$pandoc_input" --to plain --wrap=none -o "$txt"

   #  clean up text, from experience we need to
   #  - remove all html/xml artefacts
   #  - convert markdown links [description](url) to just description
   #  - remove all { and } tags and anything within those tags
   #  - remove any lines beginning with :::
   #  - remove all backslashes
   #  - remove image references like !(OEBPS/image_rsrc2J4.jpg)
   #  - remove markdown image links like ![alt text(path)](url)

   sed -i -e 's/<[^>]*>//g' \
      -e 's/!\[[^]]*\](\([^)]*\))//g' \
      -e 's/!([^)]*)//g' \
      -e 's/\[\([^]]*\)\](\([^)]*\))/\1/g' \
      -e 's/{[^}]*}//g' \
      -e '/^:::/d' \
      -e 's/\\//g' \
      -e 's/\[\]//g' \
      -e 's/\[/*/g' \
      -e 's/\]/*/g' \
      -e 's/\n\n/[============]/g' \
      -e 's/\n//g' \
      -e 's/\[============\]/\n\n/g' \
      "$txt"

   declare -l txt_lines txt_bytes txt_words
   read -r txt_lines < <(wc -l "$txt")
   read -r txt_bytes < <(wc -c <"$txt")
   read -r txt_words < <(wc -w <"$txt")
   format_commas "$txt_bytes" txt_bytes_formatted
   format_commas "$txt_words" txt_words_formatted

   info "Converted $input_text_file to plain text with $txt_lines lines, $txt_words_formatted words\n($txt_bytes_formatted bytes)"

   info "Converting $txt_lines of plain text to raw audio ... stand by"
   pv <"$txt" | piper --model "$voice_model" --length_scale "$length_scale" \
      --output-file "$wav"

   info "Now converting raw WAV audio to MP3"
   show_cmd_execute ffmpeg -i "$wav" "$target_mp3" | oneline 2>&1

   info "Tidying up ..."
   rm -f "$txt" "$wav"
   rm -rf "$tmpdir"

   # Set ID3 tags if author or book title provided
   if [ -n "$author" ] || [ -n "$book_title" ]; then
      info "Setting ID3 tags for $target_mp3"

      local tag_args=()

      if [ -n "$author" ]; then
         tag_args+=(-metadata "artist=$author")
         tag_args+=(-metadata "album_artist=$author")
      fi

      if [ -n "$book_title" ]; then
         tag_args+=(-metadata "album=$book_title")
      fi

      # Try to extract track number from filename
      local track_num
      track_num=$(extract_track_number "$input_text_file")
      if [ -n "$track_num" ]; then
         tag_args+=(-metadata "track=$track_num")
         info "Detected track number: $track_num"
      fi

      # Create a temporary file for retagging
      temp_tagged="$(mktemp).mp3"
      register_for_cleanup "$temp_tagged"
      show_cmd_execute ffmpeg -i "$target_mp3" "${tag_args[@]}" -c copy "$temp_tagged" | oneline 2>&1
      mv "$temp_tagged" "$target_mp3"
   fi

   checktext "$target_mp3"
}

# Process all input files
declare -a successes
declare -a fails

# Voice selection for Piper engine (Kokoro uses voice name, not path)
if [[ "$engine" == "piper" ]]; then
   if ! $random && [ -z "$voice_model" ]; then
      if $non_interactive; then
         # Use the first available voice in non-interactive mode
         voice_model=$(find ~/.local/share/piper/voices -name "*.onnx" | head -n 1)
         if [ -z "$voice_model" ]; then
            die "No voice models available and non-interactive mode enabled"
         fi
         info "Using default voice: $(basename "$voice_model")"
      else
         voice_model=$(find ~/.local/share/piper/voices -name "*.onnx" | fzf --height 40% --reverse --prompt="Select voice model: ")
      fi
   fi
fi

n=0
for source_file in "${source_files[@]}"; do
   n=$((n + 1))
   if [ ! -f "$source_file" ]; then
      warn "File not found: $source_file - skipping"
      fails+=("$source_file")
      continue
   fi

   info "Processing file $n of ${#source_files[@]}: $source_file"
   case "$engine" in
      kokoro)
         if convert_file_kokoro "$source_file"; then
            successes+=("$source_file")
         else
            fails+=("$source_file")
         fi
         ;;
      *)
         if convert_file "$source_file"; then
            successes+=("$source_file")
         else
            fails+=("$source_file")
         fi
         ;;
   esac
done

[ ${#successes} -eq 0 ] || info Successfully processed:
for success in "${successes[@]}"; do
   echo "• $success"
done

[ ${#fails} -eq 0 ] || errortext Failed to process:
for fail in "${fails[@]}"; do
   echo "• $fail"
done
